# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Demo mode — seeds fake data without real integrations
VITE_DEMO_MODE=true

# App URL (used for OAuth redirect URIs)
VITE_APP_URL=http://localhost:5173

# Strava (client ID is public; secret goes in Supabase Edge Function secrets)
VITE_STRAVA_CLIENT_ID=your-strava-client-id

# Garmin (client ID is public; secret goes in Supabase Edge Function secrets)
VITE_GARMIN_CLIENT_ID=your-garmin-client-id

# ─── Supabase Edge Function secrets (set via `supabase secrets set`) ───
# STRAVA_CLIENT_SECRET=
# STRAVA_WEBHOOK_VERIFY_TOKEN=
# GARMIN_CLIENT_SECRET=
# GARMIN_CONSUMER_KEY=
# GARMIN_CONSUMER_SECRET=
